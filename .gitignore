# =============================================================================
# Third Thoughts .gitignore
# =============================================================================
# This project is going public. Sensitive data (raw session logs, analysis
# outputs containing real usernames/paths/credentials) MUST stay out of git.
# =============================================================================

# ---------------------------------------------------------------------------
# Corpus data (raw session logs with private information)
# ---------------------------------------------------------------------------
corpus/
corpus-full/
corpus-split/
corpus-frozen/

# ---------------------------------------------------------------------------
# Experiment outputs (contain real usernames, project names, paths)
# ---------------------------------------------------------------------------
experiments/

# ---------------------------------------------------------------------------
# Sensitive derived data
# ---------------------------------------------------------------------------
# Contains verbatim session content with credentials and paths
data/labeled-messages.json

# ---------------------------------------------------------------------------
# Raw session log archives
# ---------------------------------------------------------------------------
docs/materials/

# ---------------------------------------------------------------------------
# Reviews containing private paths
# ---------------------------------------------------------------------------
docs/reviews/codex-review-004-006.md
docs/reviews/codex-review-013-015.md
docs/reviews/claude-review-019-022.md

# ---------------------------------------------------------------------------
# Rust build artifacts (middens/)
# ---------------------------------------------------------------------------
middens/target/
# Standard Rust patterns
*.rlib
*.rmeta
*.d

# Cargo lock is committed for binaries (middens is a CLI tool)
# Cargo.lock

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pkl
*.pickle
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# PDFs (may contain pre-redaction content; regenerate from markdown)
# ---------------------------------------------------------------------------
*.pdf

# ---------------------------------------------------------------------------
# Local Claude Code config
# ---------------------------------------------------------------------------
.claude/

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
nohup.out
